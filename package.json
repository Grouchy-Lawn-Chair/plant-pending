{
  "name": "plant-pending",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:recipe-engine": "vitest run src/engine/recipePhysicsEngine.test.ts",
    "test:recipe-engine:watch": "vitest src/engine/recipePhysicsEngine.test.ts",
    "database": "node scripts/build-garden-database.mjs",
    "database:debug": "node scripts/build-garden-database.mjs --debug",
    "database:local-sources": "node scripts/build-garden-database.mjs --local-sources",
    "fetch-images": "node scripts/fetchPlantImages.js",
    "fetch-green-acres": "node scripts/fetchGreenAcresMatches.js",
    "fetch-missing-images": "node scripts/fetchMissingImages.js",
    "enrich-green-acres-images": "node scripts/enrich-green-acres-images.mjs",
    "assign-plan-colors": "node scripts/assign-plan-colors.mjs",
    "update-green-acres": "node scripts/fetchGreenAcresMatches.js --force && node scripts/enrich-green-acres-images.mjs && node scripts/assign-plan-colors.mjs",
    "enrich-green-acres-catalog": "node scripts/enrich-green-acres-catalog-details.mjs",
    "enrich-missing-green-acres-sizes": "node scripts/enrich-green-acres-catalog-details.mjs --missing-size && node scripts/fix-green-acres-size-units.mjs",
    "clean-green-acres-names": "node scripts/clean-green-acres-names.mjs",
    "audit-green-acres-images": "node scripts/audit-green-acres-images.mjs",
    "fix-green-acres-images": "node scripts/audit-green-acres-images.mjs --apply",
    "crawl-green-acres": "node scripts/crawl-green-acres-catalog.mjs",
    "green-acres-cleanup": "npm run clean-green-acres-names && npm run fix-green-acres-images && npm run fix-green-acres-size-units",
    "recrawl-green-acres": "node scripts/crawl-green-acres-catalog.mjs",
    "fix-green-acres-size-units": "node scripts/fix-green-acres-size-units.mjs",
    "repair-green-acres-sizes": "node scripts/fix-green-acres-size-units.mjs",
    "reassign-plan-icons": "node scripts/reassign-plan-icons.mjs",
    "normalize-green-acres": "node scripts/normalize-green-acres-source.mjs",
    "database-v81": "node scripts/normalize-green-acres-source.mjs",
    "score-green-acres-design": "node scripts/score-green-acres-design.mjs",
    "database-v82": "npm run database-v81 && node scripts/score-green-acres-design.mjs",
    "database-v83": "npm run database-v82",
    "database-v84": "npm run database-v83",
    "download-source-databases": "node scripts/download-source-databases.mjs",
    "build-green-acres-source-subset": "node scripts/build-green-acres-source-subset.mjs",
    "source-backed-enrich-green-acres": "node scripts/source-backed-green-acres-enrichment.mjs",
    "database-v85b-source-backed": "npm run database-v84 && npm run source-backed-enrich-green-acres && npm run score-green-acres-design",
    "database-v85b": "npm run database-v85b-source-backed",
    "database-v91": "npm run database-v84 && npm run source-backed-enrich-green-acres && npm run score-green-acres-design",
    "database-v91-local-sources": "npm run database-v84 && npm run build-green-acres-source-subset && npm run source-backed-enrich-green-acres && npm run score-green-acres-design",
    "database-v92": "npm run database-v91",
    "database-v93": "npm run database-v92",
    "classify-green-acres-research": "node scripts/classify-green-acres-research.mjs",
    "database-v94": "npm run database-v93 && npm run classify-green-acres-research",
    "build-pro-planting-directives": "node scripts/build-pro-planting-directives.mjs",
    "database-v95": "npm run database-v94 && npm run build-pro-planting-directives",
    "database-v96": "npm run database",
    "database-v97": "npm run database",
    "database-v96-local-sources": "npm run database:local-sources",
    "database-v98": "npm run database",
    "database-v99": "npm run database",
    "database-rc": "npm run database",
    "start": "vite",
    "database:rebuild": "node scripts/build-garden-database.mjs",
    "enrich-green-acres-bis": "node scripts/enrich-green-acres-bis-product.mjs",
    "enrich-green-acres-bis:dry-run": "node scripts/enrich-green-acres-bis-product.mjs --dry-run --limit=10",
    "database:refresh-green-acres": "npm run enrich-green-acres-bis && npm run database"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "matter-js": "^0.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/matter-js": "^0.19.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^2.1.8"
  }
}
